doctype html
html(lang="ru")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

        link(rel="stylesheet" href="assets/styles/css/reset.css")
        link(rel="stylesheet" href="assets/styles/css/index.css")
        title Медиа ремесло
    body
        .page-wrapper
            .page
                .container
                    .page__grid
                        aside.sidebar
                            .sidebar__wrapper
                                .sidebar__header
                                    a(href="#").sidebar__logo.logo
                                        img.logo__img(src="assets/media/images/logo.svg")
                                    .sidebar__burger
                                        a(href="#").burger
                                            span.burger__item
                                            span.burger__item
                                            span.burger__item
                                .sidebar-nav
                                    p.sidebar-nav__title Разделы
                                    ul.sidebar-nav__list
                                        li.sidebar-nav__item
                                            a(href="#").sidebar-nav__link Продвижение
                                        li.sidebar-nav__item
                                            a(href="#").sidebar-nav__link.active Монетизация
                                        li.sidebar-nav__item
                                            a(href="#").sidebar-nav__link Контент и уаковка
                                        li.sidebar-nav__item
                                            a(href="#").sidebar-nav__link Аналитика
                                        li.sidebar-nav__item
                                            a(href="#").sidebar-nav__link Разное
                                    .sidebar-nav__footer
                                        a(href="#").button.button--small.button--full.button--dark Личный кабинет
                                        a(href="#").burger.burger--text закрыть меню

                                .sidebar__footer
                                    a(href="#").sidebar-link #[img(class="icon" src="assets/media/images/icons/user.webp")] Личный кабинет
                        main.content.page__content
                            .section
                                .section__wrapper
                                    .section__header
                                        p.text.text--middle.text--medium Личный кабинет
                                    .section__content
                                        .block.block--full
                                            .block__row
                                                p.text.text--light.text--grey Данные аккаунта
                                            .block__row
                                                p.text.text--light.text--grey--dark Ваш email: myaccount@gmail.com <br> Статус: Пробный
                                        .block.block--full.block-toggle
                                            .block__row
                                                label.block__line.block-toggle__header
                                                    input(type="checkbox" checked).block-toggle__input
                                                    p.text.text--light.text--grey Платежные данные
                                                    img.block-toggle__icon(src="assets/media/images/icons/arrow-small.svg")
                                            .block-toggle__content
                                                .block__row.tariff
                                                    p.text.text--base.text--medium.text--grey--dark Текущая подписка:
                                                    .tariff__title
                                                        p.tariff-tag Пробный
                                                        p.text.text--base.text--medium - 99 ₽
                                                    p.text.text--grey Следующий платеж: 990₽, 10.01.2026
                                                .block__row
                                                    .block__line
                                                        p.text.text--base.text--medium.text--grey--dark Привязанная карта:
                                                        a(href="#").text.text--base.text--grey.text--underline - отвязать карту
                                                    img(src="assets/media/images/icons/mir.webp").card-icon
                                                    p.text.text--base •••• •••• •••• 4321
                                                    a(href="#").text.text--base.text--grey.text--underline карта не привязана
                                                .block__row
                                                    a(href="#").button.button--base.button--dark.button--center.block__button Отменить подписку
                        .header-profile
                            .header-profile__wrapper
                                a(href="#").favorite-link Избранное
                                    img.icon(src="assets/media/images/icons/heart.webp")
                                a(href="#").account-link
                                    img.icon(src="assets/media/images/icons/user-white.webp")
        script(src="assets/scripts/index.js")



